# Database
DATABASE_URL=postgresql://user:password@localhost:5432/taler_id

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here

# Application
PORT=3000
BASE_URL=https://id.taler.tirol
NODE_ENV=production

# SMTP (email)
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=taler-documents
S3_REGION=us-east-1

# Sumsub KYC
SUMSUB_APP_TOKEN=your-sumsub-app-token
SUMSUB_SECRET_KEY=your-sumsub-secret-key
SUMSUB_WEBHOOK_SECRET=your-sumsub-webhook-secret

# Blockchain
BLOCKCHAIN_ENABLED=false
TALER_NODE_WS=wss://node.dev.gsmsoft.eu/
# Taler chain node WebSocket endpoint (used by DepositWatcher when BLOCKCHAIN_ENABLED=true)
BLOCKCHAIN_NODE_URL=wss://node.dev.gsmsoft.eu/
KYC_CONTRACT_ADDRESS=
ATTESTER_MNEMONIC=your-substrate-mnemonic

# --- TAL Billing ---
# WARNING: Rotating WALLET_ENCRYPTION_KEY orphans every existing custodial wallet.
# Rotation requires a DB migration that re-encrypts all UserWallet.custodialKeyEnc
# rows with the new key. Do NOT rotate in production without that migration.
# Must be ≥32 characters.
WALLET_ENCRYPTION_KEY=change_me_32_bytes_min_for_aes256gcm_derivation

# Shared secret for agent → /metering/report callbacks (ai-twin-agent, outbound-call-agent).
METERING_SHARED_SECRET=change_me_long_random_hex

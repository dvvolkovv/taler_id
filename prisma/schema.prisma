generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                @id @default(uuid())
  email                String?               @unique
  phone                String?               @unique
  passwordHash         String?
  deletedAt            DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  emailVerified        Boolean               @default(false)
  phoneVerified        Boolean               @default(false)
  isAdmin              Boolean               @default(false)
  username             String?               @unique
  fcmToken             String?
  voipToken            String?
  assistantTranscripts AssistantTranscript[]
  auditLogs            AuditLog[]
  kycRecord            KycRecord?
  profile              Profile?
  profileSections      ProfileSection[]
  sessions             Session[]
  tenantMembers        TenantMember[]
  totpSecret           TotpSecret?
  messages             Message[]
  notes                Note[]
  calendarEvents       CalendarEvent[]
  calendarInvites      CalendarInvite[]
}

model Profile {
  id                String     @id @default(uuid())
  userId            String     @unique
  firstName         String?
  lastName          String?
  middleName        String?
  dateOfBirth       DateTime?
  country           String?
  postalCode        String?
  walletAddress     String?
  avatarUrl         String?
  preferredCurrency String?
  language          String     @default("en")
  status            String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  personalRoomCode  String?    @unique
  documents         Document[]
  user              User       @relation(fields: [userId], references: [id])
}

model Document {
  id           String       @id @default(uuid())
  profileId    String
  type         DocumentType
  s3Key        String
  originalName String?
  mimeType     String?
  status       String       @default("uploaded")
  uploadedAt   DateTime     @default(now())
  profile      Profile      @relation(fields: [profileId], references: [id])
}

model KycRecord {
  id                String    @id @default(uuid())
  userId            String    @unique
  sumsubApplicantId String?   @unique
  status            KycStatus @default(UNVERIFIED)
  kycType           KycType   @default(INDIVIDUAL)
  rejectionReason   String?
  verifiedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id])
}

model Session {
  id         String   @id @default(uuid())
  userId     String
  deviceInfo String?
  ipAddress  String?
  location   String?
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  expiresAt  DateTime
  isRevoked  Boolean  @default(false)
  user       User     @relation(fields: [userId], references: [id])
}

model TotpSecret {
  id        String   @id @default(uuid())
  userId    String   @unique
  secret    String
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  ipAddress String?
  userAgent String?
  meta      Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model OAuthClient {
  id            String   @id @default(uuid())
  clientId      String   @unique
  clientSecret  String
  name          String
  redirectUris  String[]
  allowedScopes String[]
  logoUri       String?
  createdAt     DateTime @default(now())
}

model Tenant {
  id                String         @id @default(uuid())
  name              String
  description       String?
  logoUrl           String?
  legalAddress      String?
  website           String?
  contactEmail      String?
  contactPhone      String?
  kybStatus         KycStatus      @default(UNVERIFIED)
  sumsubApplicantId String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  members           TenantMember[]
}

model TenantMember {
  id        String     @id @default(uuid())
  tenantId  String
  userId    String
  role      TenantRole @default(VIEWER)
  invitedAt DateTime   @default(now())
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  user      User       @relation(fields: [userId], references: [id])

  @@unique([tenantId, userId])
}

model PendingInvite {
  id        String     @id @default(uuid())
  tenantId  String
  email     String
  role      TenantRole @default(VIEWER)
  token     String     @unique
  expiresAt DateTime
  createdAt DateTime   @default(now())
}

model AssistantTranscript {
  id        String   @id @default(uuid())
  userId    String
  messages  Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Conversation {
  id           String                    @id @default(uuid())
  type         ConvType                  @default(DIRECT)
  createdAt    DateTime                  @default(now())
  name         String?
  avatarUrl    String?
  description  String?
  createdById  String?
  updatedAt    DateTime  @updatedAt
  slowMode      Boolean   @default(false)
  invitePolicy  String    @default("all")
  autoDeleteDays Int?
  topicsEnabled Boolean   @default(false)
  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String
  userId         String
  role           GroupRole  @default(MEMBER)
  joinedAt       DateTime   @default(now())
  isMuted        Boolean    @default(false)
  mutedUntil     DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  sentAt         DateTime     @default(now())
  fileUrl        String?
  fileName       String?
  fileSize       Int?
  fileType       String?
  s3Key          String?
  thumbnailSmallUrl  String?
  thumbnailMediumUrl String?
  thumbnailLargeUrl  String?
  isDelivered    Boolean      @default(false)
  isRead         Boolean      @default(false)
  isSystem       Boolean      @default(false)
  isEdited       Boolean      @default(false)
  deletedAt     DateTime?
  hiddenFor     MessageHidden[]
  reactions     MessageReaction[]
  editedAt       DateTime?
  fileRecordId   String?
  threadParentId String?
  fileRecord     FileRecord? @relation(fields: [fileRecordId], references: [id])
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, sentAt])
}

model FileRecord {
  id              String   @id @default(uuid())
  sha256          String   @unique
  s3Key           String   @unique
  mimeType        String?
  size            Int
  thumbnailSmall  String?
  thumbnailMedium String?
  thumbnailLarge  String?
  refCount        Int      @default(1)
  createdAt       DateTime @default(now())
  messages        Message[]
}

enum DocumentType {
  PASSPORT
  NATIONAL_ID
  DRIVERS_LICENSE
  DIPLOMA
  CERTIFICATE
}

enum KycStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum KycType {
  INDIVIDUAL
  SELF_EMPLOYED
  BUSINESS
}

enum TenantRole {
  OWNER
  ADMIN
  OPERATOR
  VIEWER
}

enum GroupRole {
  OWNER
  ADMIN
  MEMBER
}

enum ConvType {
  DIRECT
  GROUP
}

model CallLog {
  id             String    @id @default(uuid())
  roomName       String    @unique
  initiatorId    String
  participantIds String[]
  startedAt      DateTime  @default(now())
  answeredAt     DateTime?
  endedAt        DateTime?
  durationSec    Int?
  withAi         Boolean   @default(false)
  conversationId String?
  meetingSummary MeetingSummary?
}

model PublicRoom {
  id        String    @id @default(uuid())
  code      String    @unique
  roomName  String
  creatorId String?
  title     String    @default("")
  createdAt DateTime  @default(now())
  expiresAt DateTime?
  isActive  Boolean   @default(true)
  passwordHash String?
  type      String    @default("temporary")
}

model MeetingSummary {
  id           String   @id @default(uuid())
  roomName     String
  callLogId    String?  @unique
  transcript   String   @db.Text
  summary      String   @db.Text
  keyPoints    Json     @default("[]")
  actionItems  Json     @default("[]")
  decisions    Json     @default("[]")
  participants    String[]
  participantIds  String[]
  recordingUrl    String?
  durationSec  Int?
  status       String   @default("done")
  participantTracks Json     @default("{}")
  createdAt    DateTime @default(now())

  callLog      CallLog? @relation(fields: [callLogId], references: [id])
}

model MessageHidden {
  id        String  @id @default(uuid())
  messageId String
  userId    String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
}

model ContactRequest {
  id         String               @id @default(uuid())
  senderId   String
  receiverId String
  status     ContactRequestStatus @default(PENDING)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
  @@index([senderId, status])
}

enum ContactRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum SectionType {
  VALUES
  WORLDVIEW
  SKILLS
  INTERESTS
  DESIRES
  BACKGROUND
  LIKES
  DISLIKES
}

enum SectionVisibility {
  PUBLIC
  CONTACTS
  PRIVATE
}

model ProfileSection {
  id         String            @id @default(uuid())
  userId     String
  type       SectionType
  content    Json
  visibility SectionVisibility @default(PRIVATE)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
}

// ─── Notes ───

model Note {
  id        String     @id @default(uuid())
  userId    String
  title     String
  content   String     @db.Text
  source    NoteSource @default(MANUAL)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

enum NoteSource {
  MANUAL
  ASSISTANT
}

// ─── Calendar ───

model CalendarEvent {
  id           String            @id @default(uuid())
  userId       String
  title        String
  description  String?           @db.Text
  type         CalendarEventType
  startAt      DateTime
  endAt        DateTime?
  allDay       Boolean           @default(false)
  reminderAt   DateTime?
  reminderSent Boolean           @default(false)
  displayTime  String?
  recurrence   Json?
  contactIds   String[]
  createdBy    String            @default("MANUAL")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  invites      CalendarInvite[]

  @@index([userId, startAt])
  @@index([reminderAt, reminderSent])
}

enum CalendarEventType {
  CALL
  EVENT
  REMINDER
}

// ─── Calendar Invites ───

model CalendarInvite {
  id        String            @id @default(uuid())
  eventId   String
  userId    String
  status    InviteStatus      @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  event     CalendarEvent     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId, status])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  MAYBE
}

// ─── Contact Aliases ───

model ContactAlias {
  id        String   @id @default(uuid())
  ownerId   String
  targetId  String
  customName String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ownerId, targetId])
  @@index([ownerId])
}

// ─── User Video Backgrounds ───

model UserBackground {
  id           String   @id @default(uuid())
  userId       String
  s3Key        String
  thumbnailUrl String?
  fileUrl      String
  fileName     String
  fileSize     Int
  mimeType     String
  createdAt    DateTime @default(now())

  @@index([userId])
}

model BlockedUser {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}
